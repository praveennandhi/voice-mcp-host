{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voice-mcp-host",
  "version": "0.2.1",
  "identifier": "dev.voicemcphost",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend && node scripts/prepare-macos-engine.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "settings",
        "title": "voice-mcp-host",
        "width": 720,
        "height": 560,
        "visible": true,
        "resizable": true
      },
      {
        "label": "overlay",
        "title": "voice-mcp-host overlay",
        "width": 390,
        "height": 118,
        "visible": false,
        "focus": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": ["default_config.json", "sidecars/voice_mcp_asr_sidecar.py", "sidecars/browser_readonly.mjs", "bundled/faster-whisper", "bundled/whisper-macos"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist",
      "infoPlist": "macos_info.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
