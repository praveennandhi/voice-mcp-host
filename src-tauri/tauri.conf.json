{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voice-mcp-host",
  "version": "0.1.0",
  "identifier": "dev.voicemcphost",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "settings",
        "title": "voice-mcp-host",
        "width": 720,
        "height": 560,
        "visible": true,
        "resizable": true
      },
      {
        "label": "overlay",
        "title": "voice-mcp-host overlay",
        "width": 360,
        "height": 96,
        "visible": false,
        "focus": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": ["default_config.json"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "voice-mcp-host needs the microphone to transcribe your speech."
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
